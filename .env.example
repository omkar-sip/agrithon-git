# Sarpanch AI — Environment Variables
# Copy this to .env and fill in your actual keys

# Firebase Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_VAPID_KEY=

# Gemini AI
VITE_GEMINI_API_KEY=

# PlantNet (plant identification) — https://my.plantnet.org/
# Dev server proxies /plantnet-api to avoid CORS; production should use a backend or enable CORS on PlantNet for your domain.
VITE_PLANTNET_API_KEY=
# e.g. all, weurope, india — see PlantNet projects list
VITE_PLANTNET_PROJECT=all

# Weather
VITE_OPENWEATHER_API_KEY= 

# Market / SMS
VITE_AGMARKNET_API_KEY=
VITE_MSG91_AUTH_KEY=
