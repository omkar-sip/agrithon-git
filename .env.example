# Sarpanch AI — Environment Variables
# Copy this to .env and fill in your actual keys
# Anything prefixed with VITE_ is exposed to the browser in a Vite app.
# Keep browser-side AI and SMS disabled in production unless you explicitly accept that risk.

# Firebase Configuration
VITE_FIREBASE_API_KEY="your_firebase_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_messaging_sender_id"
VITE_FIREBASE_APP_ID="your_firebase_app_id"
VITE_FIREBASE_MEASUREMENT_ID="your_measurement_id"
VITE_FIREBASE_VAPID_KEY="your_firebase_vapid_key"

# Gemini AI
VITE_GEMINI_API_KEY="your_gemini_api_key"
VITE_ALLOW_BROWSER_GEMINI=false

# Weather
VITE_OPENWEATHER_API_KEY="your_openweather_api_key"

# Market / SMS
VITE_AGMARKNET_API_KEY="your_agmarknet_api_key"
VITE_AGMARKNET_RESOURCE_ID="your_agmarknet_resource_id"
VITE_AGMARKNET_BASE_URL="https://api.data.gov.in/resource"
VITE_AGMARKNET_LIMIT=80

VITE_MSG91_AUTH_KEY="your_msg91_auth_key"
VITE_ALLOW_BROWSER_MSG91=false
VITE_MSG91_BASE_URL="https://api.msg91.com/api/v2/sendsms"
VITE_MSG91_SENDER_ID="your_msg91_sender_id"
VITE_MSG91_ROUTE=4
VITE_MSG91_COUNTRY=91
